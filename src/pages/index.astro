---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home" description="Chris Gilbert - Senior Full Stack Engineer specializing in Ruby on Rails">
  <section class="space-y-6">
    <h1 class="text-4xl font-bold">Hi, I'm Chris Gilbert</h1>
    <p class="text-xl text-gray-600">
      Senior Full Stack Engineer specializing in Ruby on Rails.
    </p>
    <div class="prose">
      <p>
        I'm passionate about writing maintainable code and take pride in owning features
        end-to-end—from discovery to delivery. Currently working at
        <a href="https://www.supercritical.com" target="_blank" rel="noopener">Supercritical</a>,
        helping businesses reach net zero through high-quality carbon removal.
      </p>
      <p>
        Based in London. Previously at Songkick and Multiverse. Former sound engineer
        turned software developer via Makers Academy.
      </p>
    </div>
    <div class="flex gap-4 pt-4">
      <a
        href="/cv"
        class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-700 transition-colors"
      >
        View CV
      </a>
      <a
        href="/blog"
        class="inline-block border border-gray-300 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors"
      >
        Read Blog
      </a>
    </div>
  </section>
</Layout>
