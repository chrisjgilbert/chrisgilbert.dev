---
import Layout from "../layouts/Layout.astro";

const experience = [
  {
    title: "Senior Software Engineer",
    company: "Supercritical",
    location: "London",
    period: "Mar 2022 - Present",
    tech: "Ruby, Rails, Turbo, Stimulus, Sinatra, MySQL, GCP",
  },
  {
    title: "Software Engineer",
    company: "Multiverse",
    location: "London",
    period: "Oct 2021 - Feb 2022",
    tech: "Elixir, Elm, Phoenix, JavaScript, React, MySQL, AWS",
  },
  {
    title: "Junior Software Engineer",
    company: "Songkick",
    location: "London",
    period: "Apr 2019 - Sep 2021",
    tech: "Ruby, Rails, Sinatra, JavaScript, React, React Native, GCP, MySQL",
  },
  {
    title: "Sound Engineer (pre career change)",
    company: "750mph, McCann, Offset Audio",
    location: "London",
    period: "2013 - 2018",
    tech: null,
  },
];


const projects = [
  {
    name: "TokenPrice",
    url: "https://tokenprice.fyi/",
    description: "LLM token pricing comparison tool",
  },
  {
    name: "Stablemate",
    url: "https://stablemate.dev/",
    description: "Horse racing data and analysis",
  },
  {
    name: "claude-ruby-quality",
    url: "https://github.com/chrisjgilbert/claude-ruby-quality",
    description: "Claude Code plugin for detecting Ruby/Rails code and test smells",
  },
  {
    name: "orra",
    url: "https://github.com/chrisjgilbert/orra",
    description: "Personal podcast generator",
  },
  {
    name: "recipes",
    url: "https://github.com/chrisjgilbert/recipes",
    description: "Personal recipe manager",
  },
];
---

<Layout title="CV" description="Chris Gilbert - Senior Full Stack Engineer specializing in Ruby on Rails">
  <article class="space-y-12">
    <header>
      <h1 class="text-4xl font-bold mb-4">Chris Gilbert</h1>
      <p class="text-xl text-gray-600">Senior Full Stack Engineer</p>
      <p class="mt-4 text-gray-700 max-w-2xl">
        Senior Full Stack Engineer specializing in Ruby on Rails. Passionate about writing
        maintainable code, I take pride in owning features end-to-end—from discovery to
        delivery—while balancing technical implementation with user experience.
      </p>
    </header>

    <section>
      <h2 class="text-2xl font-semibold mb-6 pb-2 border-b border-gray-200">
        Experience
      </h2>
      <div class="space-y-8">
        {
          experience.map((job) => (
            <div class="space-y-2">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                <h3 class="text-xl font-semibold">{job.title}</h3>
                <span class="text-sm text-gray-500">{job.period}</span>
              </div>
              <p class="text-gray-600 font-medium">
                {job.company} <span class="font-normal">· {job.location}</span>
              </p>
              {job.tech && (
                <p class="text-sm text-gray-500">{job.tech}</p>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-6 pb-2 border-b border-gray-200">
        Projects
      </h2>
      <div class="space-y-4">
        {
          projects.map((project) => (
            <div class="space-y-1">
              <a
                href={project.url}
                target="_blank"
                rel="noopener"
                class="text-blue-600 hover:underline font-medium"
              >
                {project.name}
              </a>
              <p class="text-gray-600 text-sm">{project.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-6 pb-2 border-b border-gray-200">
        Contact & Links
      </h2>
      <p class="text-gray-700">
        <a href="mailto:chris@chrisgilbert.dev" class="text-blue-600 hover:underline">
          chris@chrisgilbert.dev
        </a>
      </p>
      <p class="text-gray-700">
        <a href="https://www.linkedin.com/in/chrisjgilbert88/" target="_blank" rel="noopener" class="text-blue-600 hover:underline">
          LinkedIn
        </a>
      </p>
      <p class="text-gray-700">
        <a href="https://github.com/chrisjgilbert" target="_blank" rel="noopener" class="text-blue-600 hover:underline">
          Github
        </a>
      </p>
    </section>
  </article>
</Layout>
