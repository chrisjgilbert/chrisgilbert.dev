---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const updates = await getCollection("projectUpdates");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: {
      project,
      updates: updates
        .filter((u) => u.data.project === project.id && !u.data.draft)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
  updates: CollectionEntry<"projectUpdates">[];
}

const { project, updates } = Astro.props;
const { Content: ProjectContent } = await render(project);

const renderedUpdates = await Promise.all(
  updates.map(async (update) => ({
    update,
    Content: (await render(update)).Content,
  })),
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const statusStyles: Record<string, string> = {
  active: "bg-green-100 text-green-800",
  shipped: "bg-blue-100 text-blue-800",
  paused: "bg-yellow-100 text-yellow-800",
  archived: "bg-gray-100 text-gray-700",
};
---

<Layout title={project.data.title} description={project.data.tagline}>
  <article class="space-y-10">
    <header class="space-y-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-4xl font-bold">{project.data.title}</h1>
        <span
          class={`text-xs font-medium px-2 py-0.5 rounded-full ${statusStyles[project.data.status]}`}
        >
          {project.data.status}
        </span>
      </div>
      <p class="text-xl text-gray-600">{project.data.tagline}</p>
      <p class="text-sm text-gray-500">
        Started {formatDate(project.data.startDate)}
      </p>
      {
        project.data.links && (project.data.links.url || project.data.links.github) && (
          <p class="flex gap-4 text-sm pt-1">
            {project.data.links.url && (
              <a
                href={project.data.links.url}
                target="_blank"
                rel="noopener"
                class="text-blue-600 hover:underline"
              >
                Live
              </a>
            )}
            {project.data.links.github && (
              <a
                href={project.data.links.github}
                target="_blank"
                rel="noopener"
                class="text-blue-600 hover:underline"
              >
                GitHub
              </a>
            )}
          </p>
        )
      }
    </header>

    <section class="prose">
      <ProjectContent />
    </section>

    <section class="space-y-6">
      <h2 class="text-2xl font-semibold pb-2 border-b border-gray-200">
        Updates
      </h2>
      {
        renderedUpdates.length === 0 ? (
          <p class="text-gray-600">No updates yet.</p>
        ) : (
          <ol class="space-y-8">
            {renderedUpdates.map(({ update, Content }) => (
              <li class="space-y-2">
                <p class="text-sm text-gray-500">{formatDate(update.data.date)}</p>
                {update.data.title && (
                  <h3 class="text-lg font-semibold">{update.data.title}</h3>
                )}
                <div class="prose">
                  <Content />
                </div>
              </li>
            ))}
          </ol>
        )
      }
    </section>

    <footer class="pt-6 border-t border-gray-200">
      <a href="/projects" class="text-blue-600 hover:underline">&larr; Back to projects</a>
    </footer>
  </article>
</Layout>
