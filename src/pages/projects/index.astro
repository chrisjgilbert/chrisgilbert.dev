---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).filter(
  (p) => !p.data.draft,
);

const updates = (await getCollection("projectUpdates")).filter(
  (u) => !u.data.draft,
);

const latestUpdateByProject = new Map<string, Date>();
for (const update of updates) {
  const current = latestUpdateByProject.get(update.data.project);
  if (!current || update.data.date.valueOf() > current.valueOf()) {
    latestUpdateByProject.set(update.data.project, update.data.date);
  }
}

const projectsWithLatest = projects
  .map((project) => ({
    project,
    latestUpdate: latestUpdateByProject.get(project.id) ?? null,
  }))
  .sort((a, b) => {
    const aTime = a.latestUpdate?.valueOf() ?? a.project.data.startDate.valueOf();
    const bTime = b.latestUpdate?.valueOf() ?? b.project.data.startDate.valueOf();
    return bTime - aTime;
  });

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const statusStyles: Record<string, string> = {
  active: "bg-green-100 text-green-800",
  shipped: "bg-blue-100 text-blue-800",
  paused: "bg-yellow-100 text-yellow-800",
  archived: "bg-gray-100 text-gray-700",
};
---

<Layout title="Projects" description="Side projects and periodic updates from Chris Gilbert">
  <article class="space-y-8">
    <header>
      <h1 class="text-4xl font-bold mb-4">Projects</h1>
      <p class="text-xl text-gray-600">
        Side projects I'm tinkering with, and periodic updates as they evolve.
      </p>
    </header>

    {
      projectsWithLatest.length === 0 ? (
        <p class="text-gray-600">No projects yet. Check back soon!</p>
      ) : (
        <ul class="space-y-6">
          {projectsWithLatest.map(({ project, latestUpdate }) => (
            <li class="border-b border-gray-200 pb-6 last:border-0">
              <a href={`/projects/${project.id}`} class="group block space-y-2">
                <div class="flex items-center gap-3 flex-wrap">
                  <h2 class="text-xl font-semibold group-hover:text-gray-600 transition-colors">
                    {project.data.title}
                  </h2>
                  <span
                    class={`text-xs font-medium px-2 py-0.5 rounded-full ${statusStyles[project.data.status]}`}
                  >
                    {project.data.status}
                  </span>
                </div>
                <p class="text-gray-700">{project.data.tagline}</p>
                <p class="text-sm text-gray-500">
                  {latestUpdate
                    ? `Last update: ${formatDate(latestUpdate)}`
                    : `Started ${formatDate(project.data.startDate)}`}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </article>
</Layout>
