---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Chris Gilbert - Ruby Developer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Chris Gilbert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      data-goatcounter="https://chrisgilbert.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body class="bg-canvas text-ink antialiased">
    <div class="min-h-screen flex flex-col">
      <div class="sticky top-0 z-20 flex justify-center px-4 py-4">
        <nav class="flex items-center gap-2 bg-surface/70 backdrop-blur-xl border border-hairline rounded-full pl-5 pr-2 py-2 text-sm">
          <a href="/" class="font-semibold mr-2 hover:text-accent transition-colors">
            Chris Gilbert
          </a>
          <a href="/" class="px-3 py-1.5 rounded-full text-ink-soft hover:text-ink hover:bg-accent-soft transition-colors">Home</a>
          <a href="/cv" class="px-3 py-1.5 rounded-full text-ink-soft hover:text-ink hover:bg-accent-soft transition-colors">CV</a>
          <a href="/blog" class="px-3 py-1.5 rounded-full text-ink-soft hover:text-ink hover:bg-accent-soft transition-colors">Blog</a>
        </nav>
      </div>

      <main class="flex-1 max-w-3xl mx-auto px-4 py-12 w-full">
        <slot />
      </main>

      <footer class="border-t border-hairline">
        <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-ink-soft space-y-3">
          <ul class="flex justify-center gap-4">
            <li>
              <a href="mailto:chris@chrisgilbert.dev" class="hover:text-accent transition-colors">
                Email
              </a>
            </li>
            <li>
              <a href="https://bsky.app/profile/chrisgilbertdev.bsky.social" target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                Bluesky
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/chrisjgilbert88/" target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                LinkedIn
              </a>
            </li>
            <li>
              <a href="https://github.com/chrisjgilbert" target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                Github
              </a>
            </li>
          </ul>
          <p>&copy; {new Date().getFullYear()} Chris Gilbert. All rights reserved.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
